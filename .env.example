# --- LLM (default = local via Ollama, no API key needed) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# Only needed if you switch LLM_PROVIDER above to openai/anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Embeddings (local, free) ---
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Vector DB ---
VECTOR_DB=faiss
VECTOR_DB_PATH=./data/vector_store

TOP_K=3
